{
	"schemaVersion": 1,
	"id": "villagersb",
	"version": "${version}",
	"name": "villagersb",
	"description": "Make villagers Better!"	,
	"authors": [
		"Notenlish"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/villagersb/icon.png",
